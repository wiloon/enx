# ENX API Environment Configuration
# Copy this file to .env and modify as needed
# This file is for local development - DO NOT commit to git

# API Server Port (overrides config.toml)
ENX_PORT=8091

# Database Path
DB_PATH=/var/lib/enx-api/enx.db

# Data Service Address
# (currently not supported by env var, use config.toml)
# DATA_SERVICE_ADDRESS=localhost:50051

# Resend Email API (for user registration email verification)
# Register at: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# Youdao Dictionary API credentials (Official API)  
# Register at: https://ai.youdao.com/console/
# Documentation: https://ai.youdao.com/DOCSIRMA/html/自然语言翻译/API文档/文本翻译服务/文本翻译服务-API文档.html
# IMPORTANT: Uses official Youdao OpenAPI instead of web scraping to avoid legal issues
YOUDAO_APP_KEY=your_youdao_app_key_here
YOUDAO_APP_SECRET=your_youdao_app_secret_here
# Optional: Override default API URL (default: https://openapi.youdao.com/api)
# YOUDAO_URL=https://openapi.youdao.com/api
